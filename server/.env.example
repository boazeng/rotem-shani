# ---- Rotem Shani parking server — environment ----
# Copy to `.env` and fill in. NEVER commit the real .env (it holds secrets).

# Google OAuth client (reuse the existing bookkeeping client). Add this app's
# redirect URI to that client in Google Cloud Console:
#   https://parking.newavera.co.il/auth/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Random secret that signs the session cookie. Generate once, keep stable:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_SESSION_SECRET=

# The super-admin — always admin, cannot be removed/locked out.
AUTH_SUPER_ADMIN_EMAIL=boazen@gmail.com

# Emergency login token (bypasses Google): /emergency-login?token=...
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_EMERGENCY_TOKEN=

# The OAuth redirect URI this app registers with Google (must match the console).
AUTH_REDIRECT_URI=https://parking.newavera.co.il/auth/callback

# Where the users DB lives (SQLite). On the server keep it on a persistent path.
AUTH_DB_PATH=database/auth.db

# Local development only: set to "true" to bypass Google entirely (everyone is
# treated as admin). Leave unset/false in production. The three vars above are
# still required to be present (can be dummy values) even when disabled.
# AUTH_DISABLED=false
